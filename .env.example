
# Qwen LoRA API 配置文件示例
# 复制此文件为 .env 并修改配置

# 模型路径
QWEN_BASE_MODEL_PATH=./Qwen1.5-1.8B-Chat
QWEN_LORA_MODEL_PATH=./qwen-lora-final

# API 服务配置
QWEN_HOST=0.0.0.0
QWEN_PORT=8000

# 生成参数
QWEN_MAX_NEW_TOKENS=1024
QWEN_TEMPERATURE=0.7
QWEN_TOP_P=0.9
QWEN_REPETITION_PENALTY=1.1

# 系统提示词
QWEN_SYSTEM_PROMPT=你是一个专业的旅游行业客服，请简洁、友好地回复用户的旅游咨询，贴合旅游场景话术，保持真实回复风格。

# 设备配置（auto/cuda/cpu）
QWEN_DEVICE=auto

# 数据库配置（对话记忆功能）
QWEN_DB_PATH=conversations.db

# 高德地图 API 配置
# 申请地址：https://lbs.amap.com/dev/key/app
QWEN_AMAP_API_KEY=您的高德地图API密钥

