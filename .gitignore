# ===================== 核心忽略规则（针对LoRA微调项目） =====================
# 忽略所有LoRA权重文件夹（包括训练过程中生成的step权重和最终权重）
qwen-lora-*/
lora-*/
peft-*/

# 忽略Qwen基础模型文件夹（体积过大，无需上传）
Qwen*/
qwen*/

# 忽略虚拟环境文件夹（环境可通过requirements.txt重建）
venv/
venv2/
env/
.venv/
env/
ENV/

# 忽略环境变量文件（包含敏感信息）
.env

# ===================== Python通用忽略规则 =====================
# 忽略Python编译后的字节码文件
__pycache__/
*.py[cod]
*$py.class

# 忽略Python缓存和日志文件
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 忽略IPython相关文件
.ipynb_checkpoints
profile_default/
ipython_config.py

# ===================== 数据与压缩包忽略 =====================
# 忽略完整的训练/测试数据集（只保留data目录下的示例文件）
*.txt
*.csv
*.json
*.zip
*.rar
*.7z
# 例外：保留data目录下的所有文件（示例数据和说明）
!data/
!data/**/*

# 忽略数据库文件（避免上传敏感数据）
*.db
*.sqlite
*.sqlite3
conversations.db

# ===================== 系统与临时文件 =====================
# 忽略Windows系统文件
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN

# 忽略macOS系统文件
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# 忽略Linux系统文件
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# 忽略编辑器配置文件
.idea/
.vscode/
*.swp
*.swo
*.bak
*.tmp